  "devDependencies": {
    "@types/jest": "^29.5.3",
    "@types/node": "^20.5.1",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.0",
